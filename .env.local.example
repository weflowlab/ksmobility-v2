# ─────────────────────────────────────────────────────────────
# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요.
# .env.local 은 git 에 올라가지 않습니다.
# 배포(Vercel 등) 시에는 아래 3개를 호스팅 환경변수에도 동일하게 넣어야 합니다.
# ─────────────────────────────────────────────────────────────

# Supabase — Project Settings > Data API 의 Project URL
# 예: https://abcdefghijk.supabase.co
SUPABASE_URL=

# Supabase — Project Settings > API Keys > Secret keys 의 값 (sb_secret_... 로 시작)
#
# ⚠ 이 키는 RLS를 우회합니다. 서버에서만 씁니다.
#   - 절대 NEXT_PUBLIC_ 을 붙이지 마세요 (브라우저에 노출됩니다)
#   - 깃/슬랙/문서에 붙여넣지 마세요
#   - Publishable(공개) 키가 아니라 Secret 키입니다. 헷갈리기 쉬우니 확인하세요.
#   - 유출 시 대시보드에서 이 키만 폐기하고 새로 발급하면 됩니다.
#     (구버전 service_role JWT 를 넣어도 동작하지만, 그건 유출 시
#      JWT 시크릿 전체를 갈아야 해서 Secret key 사용을 권장합니다.)
SUPABASE_SECRET_KEY=

# 관리자 로그인 비밀번호 (/admin)
# 고객에게는 이 비밀번호만 알려주면 됩니다. Supabase 계정·키는 필요 없습니다.
# 미설정 시 로그인이 500 으로 막힙니다.
ADMIN_PASSWORD=

# (선택) 세션 서명 키. 미설정 시 ADMIN_PASSWORD 로 대체됩니다.
# 지정해 두면 비밀번호를 바꿔도 기존 로그인 세션이 유지됩니다.
# 임의의 긴 문자열 (예: openssl rand -hex 32)
ADMIN_SESSION_SECRET=